    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug CLI",
            "initCommands":["settings set target.disable-aslr false"],
            "cargo": {
                "args": [
                    "build",
                    "--bin=cli",
                    "--package=cli"
                ],
                "filter": {
                    "name": "cli",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Server",
            "initCommands":["settings set target.disable-aslr false"],
            "cargo": {
                "args": [
                    "build",
                    "--bin=soundome-server",
                    "--package=soundome-server"
                ],
                "filter": {
                    "name": "soundome-server",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug Tests",
            "initCommands":["settings set target.disable-aslr false"],
            "cargo": {
                "args": [
                    "build",
                    "--bin=tests",
                    "--package=tests"
                ],
                "filter": {
                    "name": "tests",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        },
    ]
}
