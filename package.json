{
  "name": "soundome",
  "version": "0.2.4",
  "description": "",
  "scripts": {
    "dev": "concurrently \"pnpm web:dev\" \"pnpm server:dev\"",
    "build": "pnpm web:build && pnpm server:build",
    "web:dev": "pnpm --filter @soundome/web dev",
    "web:build": "pnpm --filter @soundome/web build",
    "web:check": "pnpm --filter @soundome/web check",
    "server:dev": "cargo run -p soundome-server",
    "server:build": "cargo build -p soundome-server",
    "cargo:build": "cargo build --workspace",
    "cargo:build:release": "cargo build --workspace --release -j 4",
    "cargo:test": "cargo test -q",
    "cargo:clippy": "cargo clippy --workspace --all-targets",
    "cargo:fmt": "cargo fmt",
    "reset": "rm -rf data/soundome.db* && rm -rf library && rm -rf temp && diesel setup"
  },
  "keywords": [],
  "author": "dev.bartho@gmail.com",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "headroom-ai": "^0.1.0",
    "openrtk": "^0.1.0"
  }
}
